# Build output
build/
**/build/
*.o
*.bin
*.APPL

# Rust (host tooling, tools/atrium-tool) — target/ is generated; Cargo.lock is
# committed for reproducible CI builds (binary crate).
target/
**/target/

# Local test disk images (inject into copies, don't commit)
*.dsk
*.hda
*.img

# host unit-test binary
tests/host_test

# macOS
.DS_Store

# Prebuilt launcher is a build artifact, never tracked (Retro68 or a release drop)
tools/atrium-tool/assets/MacAtrium.bin

# Python tooling (assets/icons, macgarden-scraper, compat-matrix, builds/gen_configs.py)
__pycache__/
*.pyc
*.pyo

# Logs / spike configure output
*.log
cfg.log

# Disk-image container (*.dsk/*.hda/*.img already covered above)
*.vhd

# Generated build configs (regenerate with builds/gen_configs.py) + personal donor list
builds/gen-*.json
data/donors.json

# Editor / IDE / OS junk
*~
*.swp
*.swo
.idea/
.vscode/
Thumbs.db
